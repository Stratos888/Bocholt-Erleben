    "own_or_exclusive_premium_real_photo",
    "organizer_or_rightsholder_cleared_premium_real_photo",
    "legally_clean_high_quality_photo_with_documented_rights",
    "ai_generated_symbolic_premium_visual",
    "legacy_external_image_temporary_only"
  ],
  "visual_rules": [
    "AI visuals must be symbolic and must not claim to document a real place or real event.",
    "No readable logos, posters, brands or third-party artwork.",
    "No recognizable children.",
    "Main subject must be safe for 16:9 card crops.",
    "Weak raw images should be replaced or downgraded, not rescued through CSS crop hotfixes."
